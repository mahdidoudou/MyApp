@model MyApp.Models.Product

<!DOCTYPE html>
<html>
<head>
    <title>@Model.Name</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand">Phone Store</a>
            <div>
                <a href="/Products/Index" class="btn btn-outline-light btn-sm me-2">Back</a>
                <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="card-img-top" style="height:300px;object-fit:cover;" />
                    }
                    <div class="card-body">
                        <h3>@Model.Name</h3>
                        <p class="text-muted">@Model.Brand — @Model.Category</p>
                        <p>@Model.Description</p>
                        <h4 class="text-success">$@Model.Price</h4>
                        <p>Stock: @Model.Stock</p>
                        <p>
                            @if (Model.IsAvailable)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Not Available</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>