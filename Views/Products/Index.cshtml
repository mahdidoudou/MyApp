@model List<MyApp.Models.Product>

<!DOCTYPE html>
<html>
<head>
    <title>Phone Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand">Phone Store</a>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
    </nav>
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-3">
                <div class="card shadow-sm p-3 mb-4">
                    <h5>Filter</h5>
                    <hr />
                    <label class="fw-bold">Brand</label>
                    <div id="brandFilter">
                        @foreach (var brand in Model.Select(p => p.Brand).Distinct())
                        {
                            <div class="form-check">
                                <input class="form-check-input brand-cb" type="checkbox" value="@brand" onchange="filterProducts()">
                                <label class="form-check-label">@brand</label>
                            </div>
                        }
                    </div>
                    <hr />
                    <label class="fw-bold">Max Price: $<span id="priceVal">99999</span></label>
                    <input type="range" id="priceRange" min="0" max="99999" value="99999" class="form-range" oninput="updatePrice(this.value)">
                    <hr />
                    <button class="btn btn-secondary btn-sm w-100" onclick="resetFilters()">Reset</button>
                </div>
            </div>
            <div class="col-md-9">
                <h2 class="mb-4">Our Products</h2>
                <div class="row" id="productList">
                    @foreach (var product in Model)
                    {
                        <div class="col-md-4 mb-4 product-card" data-brand="@product.Brand" data-price="@product.Price">
                            <div class="card h-100 shadow-sm">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="card-img-top" style="height:200px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div style="height:200px;background:#eee;display:flex;align-items:center;justify-content:center;">
                                        <span class="text-muted">No Image</span>
                                    </div>
                                }
                                <div class="card-body">
                                    <h5 class="card-title">@product.Name</h5>
                                    <p class="text-muted mb-1">@product.Brand</p>
                                    <p class="card-text small">@product.Description</p>
                                    <h5 class="text-success">$@product.Price</h5>
                                    <p class="text-muted small">Stock: @product.Stock</p>
                                </div>
                                <div class="card-footer">
                                    <a href="/Products/Details/@product.Id" class="btn btn-dark btn-sm w-100">View Details</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <p id="noResults" class="text-muted d-none">No products found.</p>
            </div>
        </div>
    </div>
    <script>
            function updatePrice(val) {
                document.getElementById('priceVal').textContent = val;
                filterProducts();
            }
            function filterProducts() {
                const maxPrice = parseFloat(document.getElementById('priceRange').value);
                const checkedBrands = [...document.querySelectorAll('.brand-cb:checked')].map(cb => cb.value);
                let visible = 0;
                document.querySelectorAll('.product-card').forEach(card => {
                    const brand = card.dataset.brand;
                    const price = parseFloat(card.dataset.price);
                    const brandOk = checkedBrands.length === 0 || checkedBrands.includes(brand);
                    const priceOk = price <= maxPrice;
                    if (brandOk && priceOk) { card.style.display = ''; visible++; }
                    else { card.style.display = 'none'; }
                });
                document.getElementById('noResults').classList.toggle('d-none', visible > 0);
            }
            function resetFilters() {
                document.querySelectorAll('.brand-cb').forEach(cb => cb.checked = false);
                document.getElementById('priceRange').value = 99999;
                document.getElementById('priceVal').textContent = '99999';
                filterProducts();
            }
    </script>
</body>
</html>